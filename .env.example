# ════════════════════════════════════════════════════════
#  BioSage — Environment Variables Template
#  Copy this file to .env and fill in your keys.
#  NEVER commit .env to Git.
# ════════════════════════════════════════════════════════

# ── Groq (free cloud LLM) ────────────────────────────
# Get your key at https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── NCBI E-utilities (ClinVar, dbSNP, Gene) ───────────
# Register free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# ── OMIM ─────────────────────────────────────────────
# Request free research API at: https://www.omim.org/api
OMIM_API_KEY=your_omim_api_key_here

# ── Vector Store ─────────────────────────────────────
VECTOR_STORE=local
CHROMA_PERSIST_DIR=./data/chroma_db

# ── Server ───────────────────────────────────────────
# Railway sets PORT automatically — leave blank locally
PORT=8000

# ── Tester Access Control ─────────────────────────────
# Comma-separated API keys to give researchers.
# Leave blank to disable auth (open access).
# Example: TESTER_KEYS=abc123,def456,ghi789
TESTER_KEYS=

# ── Rate Limiting ─────────────────────────────────────
# Max requests per IP per minute on streaming endpoint.
# Set to 0 to disable.
RATE_LIMIT_RPM=20

# ── App Settings ─────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data
